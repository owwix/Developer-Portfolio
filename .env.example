PAYLOAD_SECRET=replace-with-a-long-random-string
MONGODB_URI=mongodb://127.0.0.1:27017/developer_portfolio
# Public app URL (used by Payload + metadata + blog links)
SITE_URL=http://localhost:3000
# Public-facing profile defaults used by metadata and JSON-LD.
SITE_OWNER_NAME=Your Name
SITE_OWNER_ROLE=Software Engineer
SITE_BLOG_LABEL=Lab / Notes
# Optional admin branding defaults (can still be changed in Payload globals).
CMS_TITLE=Your Name CMS
CMS_SUBTITLE=Editorial Control Center
CMS_MONOGRAM=YN
# Keep this aligned with SITE_URL unless you have a proxy split setup.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
# Optional internal CMS URL for server-side fetches (defaults to localhost:PORT).
PAYLOAD_INTERNAL_SERVER_URL=http://127.0.0.1:3000
# Optional durable media path (recommended in production).
# Example Railway volume mount: /data/media
PAYLOAD_MEDIA_DIR=./src/media
# Optional public media base path (default: /media)
PAYLOAD_MEDIA_URL=/media
PORT=3000
