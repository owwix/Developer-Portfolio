{
  "name": "developer-portfolio",
  "version": "0.1.0",
  "private": true,
  "description": "SWE portfolio CMS powered by Payload",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "next build && tsc -p tsconfig.json && PAYLOAD_CONFIG_PATH=dist/payload.config.js payload build",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.next.json"
  },
  "dependencies": {
    "@payloadcms/bundler-webpack": "^1.0.9",
    "@payloadcms/db-mongodb": "^2.0.0",
    "@payloadcms/richtext-slate": "^1.5.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "next": "^15.2.4",
    "payload": "^2.17.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.20.0"
  }
}
